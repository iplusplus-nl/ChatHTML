#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="${CHATHTML_BACKUP_DIR:-/var/backups/chathtml}"
KEY_FILE="${CHATHTML_BACKUP_KEY_FILE:-/etc/chathtml-backup.key}"
MAIN_ENV="${CHATHTML_MAIN_ENV:-/root/opt/chathtml/.env}"
SERVICE_ENV="${CHATHTML_SERVICE_ENV:-/etc/chathtml-service.env}"
RETENTION_DAYS="${CHATHTML_BACKUP_RETENTION_DAYS:-14}"
STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
WORK="$(mktemp -d /var/tmp/chathtml-backup.XXXXXX)"
PLAIN="$WORK/chathtml-$STAMP.tar.gz"
FINAL="$BACKUP_DIR/chathtml-$STAMP.tar.gz.gpg"

cleanup() {
  rm -rf -- "$WORK"
}
trap cleanup EXIT

read_env() {
  local file="$1"
  local key="$2"
  sed -n "s/^${key}=//p" "$file" | tail -n 1
}

DATABASE_URL="$(read_env "$MAIN_ENV" CHATHTML_DATABASE_URL)"
SERVICE_DATABASE="$(read_env "$SERVICE_ENV" DATABASE_PATH)"
if [[ -z "$DATABASE_URL" || -z "$SERVICE_DATABASE" ]]; then
  echo "Required database configuration is missing." >&2
  exit 1
fi
if [[ ! -s "$KEY_FILE" ]]; then
  echo "Backup encryption key is missing." >&2
  exit 1
fi

install -d -m 0700 "$BACKUP_DIR"
install -d -m 0700 "$WORK/payload"

pg_dump \
  --dbname="$DATABASE_URL" \
  --format=custom \
  --no-owner \
  --no-acl \
  --file="$WORK/payload/postgres.dump"

sqlite3 "$SERVICE_DATABASE" ".timeout 10000" \
  ".backup '$WORK/payload/service.sqlite'"

tar -C / -czf "$WORK/payload/chathtml-data.tar.gz" root/opt/chathtml-data
(
  cd "$WORK/payload"
  sha256sum postgres.dump service.sqlite chathtml-data.tar.gz > SHA256SUMS
)
tar -C "$WORK/payload" -czf "$PLAIN" .

gpg --batch --yes --quiet --symmetric --cipher-algo AES256 \
  --pinentry-mode loopback --passphrase-file "$KEY_FILE" \
  --output "$FINAL.tmp" "$PLAIN"
chmod 0600 "$FINAL.tmp"
mv "$FINAL.tmp" "$FINAL"

/usr/local/sbin/chathtml-restore-verify "$FINAL"

if [[ -x /usr/local/sbin/chathtml-backup-upload ]]; then
  /usr/local/sbin/chathtml-backup-upload "$FINAL"
fi

find "$BACKUP_DIR" -maxdepth 1 -type f -name 'chathtml-*.tar.gz.gpg' \
  -mtime "+$RETENTION_DAYS" -delete
echo "Created and restore-verified $FINAL"
